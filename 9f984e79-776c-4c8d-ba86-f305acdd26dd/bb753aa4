(function()
    local url =
        "https://raw.githubusercontent.com/Kyoukara/Flycer/refs/heads/main/9f984e79-776c-4c8d-ba86-f305acdd26dd/15d37af4"

    local function notify(title, text)
        pcall(
            function()
                game:GetService("StarterGui"):SetCore(
                    "SendNotification",
                    {
                        Title = title,
                        Text = text,
                        Duration = 4
                    }
                )
            end
        )
    end

    local function smartGet(u)
        local ok, result
        if
            pcall(
                function()
                    return game.HttpGetAsync
                end
            ) and typeof(game.HttpGetAsync) == "function"
         then
            ok, result =
                pcall(
                function()
                    return game:HttpGetAsync(u)
                end
            )
            if ok and result then
                notify("LOADER", "Loaded via FastFetch")
                return result
            end
        end

        ok, result =
            pcall(
            function()
                return game:HttpGet(u)
            end
        )
        if ok and result then
            notify("LOADER", "Loaded via SafeFetch")
            return result
        end

        notify("Loader", "SCRIPT GAGAL!")
        return nil
    end

    local src = smartGet(url)
    if src then
        local ok, err =
            pcall(
            function()
                loadstring(src)()
            end
        )
        if not ok then
            notify("Loader", "SCRIPT TIDAK DIJALANKAN!")
        end
    end
end)()
