-- Frame utama (ukuran konkret agar TextScaled/AutomaticSize bekerja prediktabel)
local function buildFrame(gui)
    local frame =
        new(
        "Frame",
        {
            Name = randomName(),
            Parent = gui,
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 1.2, 0),
            Size = UDim2.new(0, 460, 0, 130),
            BackgroundColor3 = Color3.fromRGB(18, 18, 20),
            BackgroundTransparency = 0.3,
            BorderSizePixel = 0
        }
    )
    new("UICorner", {Parent = frame, CornerRadius = UDim.new(0, 10)})
    new("UIStroke", {Parent = frame, Color = Color3.fromRGB(80, 120, 255), Thickness = 1, Transparency = 0.7})
    new("UIAspectRatioConstraint", {Parent = frame, AspectRatio = 460 / 130, DominantAxis = Enum.DominantAxis.Width})
    return frame
end

-- Title
local function buildTitle(frame)
    local title = Instance.new("TextLabel")
    title.Name = randomName()
    title.Parent = frame
    title.Text = "FLYCER SCRIPT STATUS"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.Font = Enum.Font.FredokaOne
    title.TextSize = 18
    title.TextScaled = true
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.BackgroundTransparency = 1
    title.Position = UDim2.new(0.04, 0, 0.07, 0)
    title.Size = UDim2.new(0.7, 0, 0.25, 0)

    -- Warna kedip biru keunguan <-> putih
    local colorA = Color3.fromRGB(138, 43, 226)
    local colorB = Color3.fromRGB(255, 255, 255)
    local t = 0
    local speed = 0.2

    local conn =
        RunService.RenderStepped:Connect(
        function(delta)
            t = t + delta * speed
            local alpha = (math.sin(t * math.pi * 2) + 1) / 2
            pcall(
                function()
                    title.TextColor3 = colorA:Lerp(colorB, alpha)
                end
            )
        end
    )
    track(conn)

    return title
end

-- Garis horizontal gradient di bawah judul
-- offsetY: nilai pixel tambahan untuk geser garis vertikal (bisa negatif untuk naik, positif untuk turun)
local function buildTitleLine(frame, title, offsetY)
    offsetY = offsetY or 5 -- default offset (pixel)

    pcall(
        function()
            local garis = Instance.new("Frame")
            garis.Name = randomName()
            garis.Parent = frame
            garis.Size = UDim2.new(1, -10, 0, 2)
            garis.BackgroundTransparency = 0
            garis.BorderSizePixel = 0
            garis.ZIndex = 10

            local grad = Instance.new("UIGradient")
            grad.Name = randomName()
            grad.Parent = garis
            grad.Rotation = 0
            grad.Color =
                ColorSequence.new(
                {
                    ColorSequenceKeypoint.new(0.00, Color3.fromRGB(80, 160, 255)),
                    ColorSequenceKeypoint.new(0.45, Color3.fromRGB(180, 80, 255)),
                    ColorSequenceKeypoint.new(0.50, Color3.fromRGB(200, 70, 255)),
                    ColorSequenceKeypoint.new(0.55, Color3.fromRGB(180, 80, 255)),
                    ColorSequenceKeypoint.new(1.00, Color3.fromRGB(80, 160, 255))
                }
            )
            grad.Transparency =
                NumberSequence.new(
                {
                    NumberSequenceKeypoint.new(0.00, 1),
                    NumberSequenceKeypoint.new(0.25, 0.2),
                    NumberSequenceKeypoint.new(0.45, 0),
                    NumberSequenceKeypoint.new(0.50, 0),
                    NumberSequenceKeypoint.new(0.55, 0),
                    NumberSequenceKeypoint.new(0.75, 0.2),
                    NumberSequenceKeypoint.new(1.00, 1)
                }
            )

            -- fungsi untuk update posisi garis berdasarkan title dan offset (menghitung pixel relatif ke frame)
            local function updatePos()
                pcall(
                    function()
                        if not title.Parent then
                            return
                        end
                        -- pastikan AbsoluteSize/Position tersedia
                        local titleAbsPos = title.AbsolutePosition
                        local titleAbsSize = title.AbsoluteSize
                        local frameAbsPos = frame.AbsolutePosition
                        local localY = (titleAbsPos.Y - frameAbsPos.Y) + titleAbsSize.Y + offsetY
                        garis.Position = UDim2.new(0, 5, 0, math.max(0, math.floor(localY)))
                    end
                )
            end

            updatePos()

            local conn =
                RunService.RenderStepped:Connect(
                function()
                    if not garis or not garis.Parent then
                        if conn then
                            conn:Disconnect()
                        end
                        return
                    end
                    pcall(updatePos)
                end
            )
            track(conn)
        end
    )
end

-- Deskripsi: UIListLayout container + helper tambah paragraf
local function buildDescContainer(frame)
    local container = Instance.new("Frame")
    container.Name = randomName()
    container.Parent = frame
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(0.92, 0, 0.56, 0)
    container.Position = UDim2.new(0.04, 0, 0.42, 0)
    container.ClipsDescendants = false

    -- Layout otomatis, padding rapat
    local layout = Instance.new("UIListLayout")
    layout.Name = randomName()
    layout.Parent = container
    layout.FillDirection = Enum.FillDirection.Vertical
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 1) -- jarak antar paragraf: 1px (rapat)

    return container
end

-- addDescText: jika index==1 (atau container kosong) otomatis GothamBold
local function addDescText(container, text, index)
    local currentIndex = 1
    pcall(
        function()
            local count = 0
            for _, v in ipairs(container:GetChildren()) do
                if v:IsA("TextLabel") then
                    count = count + 1
                end
            end
            currentIndex = count + 1
        end
    )
    if index and type(index) == "number" then
        currentIndex = index
    end

    local lbl = Instance.new("TextLabel")
    lbl.Name = randomName()
    lbl.Parent = container
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, 0, 0, 0)
    lbl.AutomaticSize = Enum.AutomaticSize.Y
    lbl.Text = text or ""
    lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    lbl.TextWrapped = true
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextYAlignment = Enum.TextYAlignment.Top

    -- FIX PALING PENTING
    lbl.TextScaled = false
    lbl.RichText = false

    -- TextSize custom TIDAK akan override lagi
    if currentIndex == 1 then
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 16
    else
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 13
    end

    -- Recalculate tinggi (fix scaling Roblox)
    task.delay(
        0.01,
        function()
            pcall(
                function()
                    local bound = lbl.TextBounds.Y
                    lbl.Size = UDim2.new(1, 0, 0, bound + 3)
                end
            )
        end
    )

    return lbl
end

