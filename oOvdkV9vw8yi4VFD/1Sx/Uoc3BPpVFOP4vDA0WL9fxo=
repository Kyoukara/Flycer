local function randomName()
    local function randomHex(len)
        local str = ""
        for _ = 1, len do
            str = str .. string.format("%x", math.random(0, 15))
        end
        return str
    end

    return string.format(
        "%s-%s-4%s-%x%s-%s",
        randomHex(8),
        randomHex(4),
        randomHex(3),
        math.random(8, 11),
        randomHex(3),
        randomHex(12)
    )
end

