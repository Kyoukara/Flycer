local function getWIB()
    local utc = os.time()
    local wib = utc + 25200 -- +7 jam
    local waktu = os.date("!%H.%M WIB", wib)
    local tanggal = os.date("!%A, %d %B %Y", wib)
    return waktu, tanggal
end


