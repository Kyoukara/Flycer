    blur = nil,
    connections = {},
    destroyed = false
}

-- Safe pcall
local function safe(fn)
    local ok, res = pcall(fn)
    return ok, res
end

-- Resolver parent
local function getParent(inst)
    -- Jika memakai Synapse atau executor yang punya protect_gui
    if syn and syn.protect_gui then
        -- Jika ada hidden UI
        syn.protect_gui(inst)
        return CoreGui
    elseif gethui then
        -- Jika tidak ada keduanya
        return gethui()
    else
        return CoreGui
    end
end

-- Membuat instance (helper random seed name V4)
local function new(class, props)
    local inst = Instance.new(class)

    pcall(
        function()
            inst.Name = "F" .. randomName()
        end
    )

    for k, v in pairs(props or {}) do
        pcall(
            function()
                inst[k] = v
            end
        )
    end

    return inst
end

-- Track connection
local function track(c)
    if c then
        table.insert(Module.connections, c)
    end
end

-- Disconnect semua koneksi
local function disconnectAll()
    for _, c in ipairs(Module.connections) do
        pcall(
            function()
                (c.Disconnect or c.disconnect)(c)
            end
        )
    end
    Module.connections = {}
end

-- Cleanup UI & blur total dengan Close Bounce smooth
local function cleanup()
    if Module.destroyed then
        return
    end
    Module.destroyed = true

    if Module.frame then
        local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        local goal = {Position = UDim2.new(0.5, 0, -0.2, 0)}
        local tween = TweenService:Create(Module.frame, tweenInfo, goal)
        tween:Play()
        tween.Completed:Wait()
    end

    for i = 20, 0, -1 do
        local alpha = i / 20
        pcall(
            function()
                if Module.blur then
                    Module.blur.Size = alpha * 24
                end
            end
        )
        task.wait(0.02)
    end

    pcall(disconnectAll)
    if Module.blur then
        pcall(
            function()
                Module.blur:Destroy()
            end
        )
    end
    if Module.gui then
        pcall(
            function()
                Module.gui:Destroy()
            end
        )
    end

    Module.gui = nil
    Module.frame = nil
    Module.blur = nil

    _G.__FLYCER_STATUS_RUNNING = false
end

