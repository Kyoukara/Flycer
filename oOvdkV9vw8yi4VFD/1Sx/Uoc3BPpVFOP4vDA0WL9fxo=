-- Auto-center
local function autoCenter(frame)
    local conn
    conn =
        RunService.RenderStepped:Connect(
        function()
            if Module.destroyed or not frame then
                if conn then
                    conn:Disconnect()
                end
                return
            end
            frame.Position = UDim2.new(0.5, 0, 0.5, 0)
        end
    )
    track(conn)
end

-- Init
local function init()
    local parent = getParent()
    if not parent then
        return
    end

    safe(
        function()
            local old = parent:FindFirstChild("FLYCERStatusUI_BOUNCE_FINAL")
            if old then
                old:Destroy()
            end
        end
    )

    createBlur()
    Module.gui = buildGui(parent)
    Module.frame = buildFrame(Module.gui)

    local titleLabel = buildTitle(Module.frame)
    buildTitleLine(Module.frame, titleLabel, 6)

    -- build Description (UIListLayout)
    local descContainer = buildDescContainer(Module.frame)
    addDescText(descContainer, "STATUS SCRIPT SAAT INI SEDANG OFFLINE / PATCHED!?")
    addDescText(descContainer, "× Server script hub mungkin sedang maintenance")
    addDescText(descContainer, "× Owner Flycer sedang melakukan update")
    addDescText(descContainer, "× Script sedang dalam masa pengembangan & perbaikan")

    buildClose(Module.frame)

    local tweenInfo = TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    local goal = {Position = UDim2.new(0.5, 0, 0.5, 0)}
    local tween = TweenService:Create(Module.frame, tweenInfo, goal)
    tween:Play()
    tween.Completed:Wait()

    autoCenter(Module.frame)

    task.spawn(
        function()
            for i = 0, 20 do
                local alpha = i / 20
                pcall(
                    function()
                        if Module.blur then
                            Module.blur.Size = alpha * 24
                        end
                    end
                )
                task.wait(0.02)
            end
        end
    )

    Module.destroyed = false
end

pcall(init)
_G.FLYCER_CLEANUP = cleanup
