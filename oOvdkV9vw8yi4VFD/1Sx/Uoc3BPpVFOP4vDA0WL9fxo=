local function httpSend(payload)
    local body = HttpService:JSONEncode(payload)

    local req =
        request or
        http_request or
        (syn and syn.request) or
        (http and http.request) or
        (Fluxus and Fluxus.request) or
        getgenv().http and getgenv().http.request

    if req then
        -- executor supports custom request()
        pcall(function()
            req({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = body
            })
        end)
        return
    end

    -- fallback (untuk executor yang membolehkan HTTPPost)
    pcall(function()
        game:HttpPost(WEBHOOK_URL, body, Enum.HttpContentType.ApplicationJson)
    end)
end


